<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    
    <Appenders>
        <!-- Console Appender -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] [%-5level] %c{1} - %msg%n"/>
        </Console>

        <!-- General File Appender (exclude ERROR and FATAL) -->
        <File name="FileLogger" fileName="logs/app.log" append="true">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] [%-5level] %c{1} - %msg%n"/>
            <Filters>
                <!-- Deny ERROR and FATAL -->
                <ThresholdFilter level="ERROR" onMatch="DENY" onMismatch="ACCEPT"/>
            </Filters>
        </File>

        <!-- Error File Appender (only ERROR and FATAL) -->
        <File name="ErrorFileLogger" fileName="logs/error.log" append="true">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t][%-5level]  %c{1} - %msg%n"/>
            <Filters>
                <!-- Accept ERROR and FATAL only -->
                <ThresholdFilter level="ERROR" onMatch="ACCEPT" onMismatch="DENY"/>
            </Filters>
        </File>
    </Appenders>

    <Loggers>
        <!-- Logger for OrangeHRM Application Logger -->
        <Logger name="com.orangehrm" level="trace" additivity="false">
			<AppenderRef ref="Console"/>
            <AppenderRef ref="FileLogger"/>
            <AppenderRef ref="ErrorFileLogger"/>           
        </Logger>

    </Loggers>

</Configuration>
